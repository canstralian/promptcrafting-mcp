// wrangler.jsonc — promptcrafting.net MCP Server
// Security-hardened prompt engineering framework
{
  "name": "promptcrafting-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-07",
  "compatibility_flags": ["nodejs_compat"],

  // ---------- Observability ----------
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },

  // ---------- Workers AI ----------
  "ai": {
    "binding": "AI"
  },

  // ---------- Durable Objects ----------
  "durable_objects": {
    "bindings": [
      {
        "name": "MCP_SERVER",
        "class_name": "PromptMCPServer"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["PromptMCPServer"]
    }
  ],

  // ---------- KV Namespaces ----------
  "kv_namespaces": [
    {
      "binding": "PROMPT_TEMPLATES",
      "id": "<PROMPT_TEMPLATES_KV_ID>"
    }
  ],

  // ---------- D1 Databases ----------
  "d1_databases": [
    {
      "binding": "AUDIT_DB",
      "database_name": "promptcrafting-audit",
      "database_id": "<AUDIT_DB_ID>"
    }
  ],

  // ---------- Rate Limiting ----------
  "rate_limits": [
    {
      "binding": "RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 100,
        "period": 60
      }
    },
    {
      "binding": "BURST_LIMITER",
      "namespace_id": "1002",
      "simple": {
        "limit": 10,
        "period": 10
      }
    }
  ],

  // ---------- Environment Variables ----------
  // Secrets set via: wrangler secret put <NAME>
  //   JWT_SECRET        — HMAC key for JWT verification (RS256 preferred; see auth middleware)
  //   TEMPLATE_HMAC_KEY — HMAC-SHA256 key for template content signing
  //   OPENAI_API_KEY    — (optional) if using external model providers
  //
  // Non-secret vars:
  "vars": {
    "ENVIRONMENT": "production",
    "LOG_LEVEL": "info",
    "HITL_TIMEOUT_MS": "300000",
    "MAX_PROMPT_LENGTH": "50000"
  }
}
