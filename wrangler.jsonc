// wrangler.jsonc — promptcrafting.net MCP Server
// Security-hardened prompt engineering framework
{
  "name": "promptcrafting-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-07",
  "compatibility_flags": ["nodejs_compat"],

  // ---------- Observability ----------
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },

  // ---------- Workers AI ----------
  "ai": {
    "binding": "AI"
  },

  // ---------- Durable Objects ----------
  "durable_objects": {
    "bindings": [
      {
        "name": "MCP_SERVER",
        "class_name": "PromptMCPServer"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["PromptMCPServer"]
    }
  ],

  // ---------- KV Namespaces ----------
  "kv_namespaces": [
    {
      "binding": "PROMPT_TEMPLATES",
      "id": "<PROMPT_TEMPLATES_KV_ID>"
    }
  ],

  // ---------- D1 Databases ----------
  "d1_databases": [
    {
      "binding": "AUDIT_DB",
      "database_name": "promptcrafting-audit",
      "database_id": "<AUDIT_DB_ID>"
    }
  ],

  // ---------- Rate Limiting ----------
  "rate_limits": [
    {
      "binding": "RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 100,
        "period": 60
      }
    },
    {
      "binding": "BURST_LIMITER",
      "namespace_id": "1002",
      "simple": {
        "limit": 10,
        "period": 10
      }
    }
  ],

  // ---------- Environment Variables ----------
  // Secrets set via: wrangler secret put <NAME>
  //
  //   JWT_SECRET        — HMAC-SHA256 key for JWT signing and verification.
  //                       Algorithm is pinned to HS256 in src/middleware/auth.ts.
  //                       Asymmetric algorithms (RS256/ES256) are intentionally NOT used
  //                       here: this is a single-issuer, server-controlled service where
  //                       the signing and verification keys are both private. HS256 avoids
  //                       the algorithm-confusion attack surface introduced by asymmetric
  //                       schemes when the public key is attacker-controllable.
  //                       To rotate: generate a new secret, update via `wrangler secret put
  //                       JWT_SECRET`, then re-issue all active tokens.
  //
  //   TEMPLATE_HMAC_KEY — HMAC-SHA256 key for template content signing (B3 integrity).
  //                       Used by prompt-builder.ts signContent() and verifyContent().
  //
  //   OPENAI_API_KEY    — (optional) if using external OpenAI-compatible model providers
  //                       instead of Workers AI. Not currently implemented.
  //                       ⚠️ If external providers are added: TLS certificate pinning is
  //                       REQUIRED per docs/security/tls-policy.md. Current architecture
  //                       uses only Cloudflare native bindings (Workers AI, D1, KV) which
  //                       are secured by Cloudflare's internal TLS infrastructure.
  //
  // Non-secret vars:
  "vars": {
    "ENVIRONMENT": "production",
    "LOG_LEVEL": "info",
    "HITL_TIMEOUT_MS": "300000",
    "MAX_PROMPT_LENGTH": "50000"
  }
}
