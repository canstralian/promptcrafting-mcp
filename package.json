{
  "name": "promptcrafting-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "Security-hardened prompt engineering framework — MCP server on Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "check": "tsc --noEmit && echo '✓ Types OK'",
    "db:migrate": "wrangler d1 execute promptcrafting-audit --file=migrations/0001_init.sql",
    "db:migrate:local": "wrangler d1 execute promptcrafting-audit --local --file=migrations/0001_init.sql",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "agents": "^0.1.0",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.3",
    "@cloudflare/workers-types": "^4.20250307.0",
    "better-sqlite3": "^12.8.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.0.0"
  }
}
